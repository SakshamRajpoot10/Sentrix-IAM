# ═══════════════════════════════════════════════════════════════
# SENTRIX — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL 17) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentrix
DB_USER=sentrix
DB_PASSWORD=your_secure_password_here

# ─── Redis 7.4 ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT Secrets (MUST be at least 256 bits / 32 chars) ──────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-to-a-secure-random-string-at-least-256-bits-long
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-at-least-256-bits

# ─── Razorpay (get from https://dashboard.razorpay.com) ──────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── ML Service ──────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_INTERNAL_API_KEY=sentrix-ml-internal-key-change-in-prod
ML_ENABLED=true

# ─── Email (SMTP) ────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Server ──────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
