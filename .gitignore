# ═══════════════════════════════════════════════════════════════
# SENTRIX — Git Ignore
# ═══════════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────────
.env
.env.local
.env.production

# ─── Java / Gradle ───────────────────────────────────────────
backend/build/
backend/.gradle/
backend/bin/
backend/out/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*

# ─── IDE ─────────────────────────────────────────────────────
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Node / Frontend ────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Python / ML ─────────────────────────────────────────────
ml/__pycache__/
ml/**/__pycache__/
ml/.venv/
ml/venv/
ml/*.pyc
ml/**/*.pyc
ml/models/saved/*.joblib
ml/models/saved/*.pt
ml/models/saved/*.pkl
ml/.pytest_cache/
ml/.mypy_cache/
*.egg-info/
dist/

# ─── SDK ─────────────────────────────────────────────────────
sdk/python/build/
sdk/python/dist/
sdk/python/*.egg-info/
sdk/javascript/node_modules/
sdk/javascript/dist/

# ─── Docker ──────────────────────────────────────────────────
docker-compose.override.yml

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Coverage ────────────────────────────────────────────────
coverage/
htmlcov/
.coverage
*.lcov

# ─── Local Binaries & Runtimes ──────────────────────────────
postgres/
redis/
python312/
backend/jdk21/
node_modules/
*.exe
*.rdb
backend_startup.log
frontend_install.log
dump.rdb
pgadmin_servers.json
